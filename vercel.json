{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/app.js"
    }
  ],
  "functions": {
    "app.js": {
      "maxDuration": 30,
      "includeFiles": [
        "views/**",
        "node_modules/mysql2/**",
        "node_modules/sequelize/**"
      ]
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
